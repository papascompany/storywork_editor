// StoryWork — Prisma Schema v1
// 단일 진실 원천: docs/data-schema/erd.md
// 변경은 반드시 prisma migrate dev 로 버전 관리 (in-place 수정 금지)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  user
  creator
  curator
  support
  superadmin
  readonly
}

enum ResourceKind {
  pose
  background
  mise_en_scene
  prop
  speech_bubble
  word_fx
  decoration
}

/// 자산 포맷 — 1차: png. 향후 svg 병행 (ADR-0011)
enum ResourceFormat {
  png
  svg
  webp
}

enum OwnerType {
  system
  creator
}

enum ResourceStatus {
  draft
  review
  published
  rejected
}

enum ProjectStatus {
  drafting
  composing
  editing
  publishing
  archived
}

enum JobStatus {
  queued
  running
  succeeded
  failed
}

enum ShowcaseMode {
  contest
  gallery
}

enum InquiryStatus {
  OPEN
  REPLIED
  CLOSED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  role          Role           @default(user)
  stripeId      String?        @unique
  /// 표시 이름 (최대 80자). null 이면 이메일 앞부분(@-prefix) 사용
  name          String?        @db.VarChar(80)
  /// 아바타 이미지 URL (외부 URL 허용). null 이면 이니셜 fallback
  avatarUrl     String?        @db.VarChar(500)
  /// 관리자 TOTP 시크릿 (Base32, otplib 생성) — 서버 사이드 전용, 절대 클라이언트 노출 금지
  totpSecret    String?
  /// TOTP 설정 완료 여부
  totpVerified  Boolean        @default(false)
  /// 회원 탈퇴 soft delete 시각 — null 이면 활성 계정 (LEGAL-OPS-03)
  deletedAt     DateTime?
  /// hard delete 예정 시각 (deletedAt + 30일). cron 이 이 값 기준으로 영구 삭제 (LEGAL-OPS-03)
  deletionScheduledFor DateTime?
  /// 탈퇴 사유 (분석용, 선택) — "비용" | "사용성" | "기능 부족" | "기타"
  deletionReason String?       @db.VarChar(200)
  /// 마케팅 수신 동의 (서비스 이용약관과 별도) — LEGAL-OPS-07
  marketingConsent Boolean     @default(false)
  /// 마케팅 동의 변경 시각 (기록용)
  marketingConsentAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects         Project[]
  resources        Resource[]       @relation("CreatorResources")
  characters       Character[]      @relation("CreatorCharacters")
  showcases        Showcase[]
  subscriptions    Subscription[]
  notices          Notice[]
  inquiries        Inquiry[]
  comments         Comment[]
  printerProfiles    PrinterProfile[]
  companyInfoUpdates CompanyInfo[]

  @@index([role])
  @@index([deletedAt])
  @@index([deletionScheduledFor])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  plan             String
  status           String
  currentPeriodEnd DateTime
  uploadQuotaMb    Int      @default(100)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

/// 인쇄 판형 — 폭/높이/dpi/여백 규격
model Format {
  id        String     @id @default(cuid())
  name      String     @unique
  widthMm   Float
  heightMm  Float
  dpi       Int        @default(300)
  bleedMm   Float      @default(3)
  safeMm    Float      @default(5)
  gridDef   Json?
  /// 표지(Cover) 설정 — admin 기본 정책. 편집기 실제 소비는 phase 2(FOLLOWUP-COVER-01)
  /// 표지 사용 유무 (이 판형의 기본값)
  coverEnabled  Boolean @default(false)
  /// 표지 독립 폭(mm) — null 이면 widthMm 사용
  coverWidthMm  Float?
  /// 표지 독립 높이(mm) — null 이면 heightMm 사용
  coverHeightMm Float?
  /// 판형 활성화/비활성화 — false 면 편집기 판형 선택에서 숨김(phase 2 소비)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  templates Template[]
  projects  Project[]
}

/// 페이지 단위 레이아웃 템플릿
model Template {
  id         String       @id @default(cuid())
  formatId   String
  format     Format       @relation(fields: [formatId], references: [id])
  name       String
  thumbnail  String?
  fabricJson Json
  slots      Json // Slot[]
  setId      String?
  set        TemplateSet? @relation(fields: [setId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([formatId])
  @@index([setId])
}

/// 여러 템플릿을 묶는 세트 (한 작품용 통합 레이아웃)
model TemplateSet {
  id        String     @id @default(cuid())
  name      String
  coverIdx  Int        @default(0)
  /// 표지(Cover) 오버라이드 — null 이면 Format 기본값 상속.
  /// effective = set.coverEnabled ?? format.coverEnabled (size 동일 규칙)
  /// null=상속, true=사용, false=미사용
  coverEnabled  Boolean?
  /// 표지 독립 폭(mm) 오버라이드 — null 이면 Format 값 상속
  coverWidthMm  Float?
  /// 표지 독립 높이(mm) 오버라이드 — null 이면 Format 값 상속
  coverHeightMm Float?
  /// 세트 활성화/비활성화
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  templates Template[]
}

/// 캐릭터 — 여러 포즈를 묶는 단위 (시스템 캐릭터 or 크리에이터 정의)
model Character {
  id          String         @id @default(cuid())
  ownerType   OwnerType
  /// system 캐릭터는 null, creator 캐릭터는 User.id
  ownerId     String?
  owner       User?          @relation("CreatorCharacters", fields: [ownerId], references: [id], onDelete: SetNull)
  name        String
  description String?
  bodyType    String
  /// "흑백 스케치", "수채화" 등 스타일 태그
  styleTag    String?
  thumbnail   String?
  status      ResourceStatus @default(draft)
  poses       Resource[]     @relation("CharacterPoses")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([ownerType, ownerId])
  @@index([status])
}

/// 관리자 등록 리소스 (포즈/배경/소품 등 모두)
model Resource {
  id               String                       @id @default(cuid())
  /// URL-safe 식별자 (한글/공백/괄호 정규화)
  slug             String                       @unique
  /// 원본 파일명 보존 (검색·디버그용)
  originalFilename String
  kind             ResourceKind
  /// 1차: png. 향후 svg 병행 (ADR-0011)
  format           ResourceFormat               @default(png)
  ownerType        OwnerType
  ownerId          String?
  owner            User?                        @relation("CreatorResources", fields: [ownerId], references: [id])
  /// 마스터 파일 URL (PNG/SVG)
  fileUrl          String
  thumbUrl         String?
  /// PNG 파생본 { webp1x, webp2x, avif?, thumb }
  variants         Json?
  /// 마스터 픽셀 너비
  width            Int?
  /// 마스터 픽셀 높이
  height           Int?
  /// PNG 한정 인쇄 환산 dpi. SVG=null
  masterDpi        Int?
  /// ai-layout 슬롯 제약 트리거 — true 면 페이지 1/2 이하 슬롯만 허용 (ADR-0011a)
  lowDpi           Boolean                      @default(false)
  /// PNG 색상 변경용 알파 마스크 URL (선택)
  tintMaskUrl      String?
  /// kind별 다형 메타 (PoseMeta 등)
  meta             Json
  tags             String[]
  /// 파일명 키워드로 자동 추출된 태그 (감사용)
  tagsBootstrap    String[]
  /// 라이선스 정보 { id, holder, terms, source, commercialUse, ... }
  license          Json
  /// 'folder-default' | 'sidecar' | 'override'
  licenseSource    String
  /// kind='pose' 일 때 소속 캐릭터 FK (선택)
  characterId      String?
  character        Character?                   @relation("CharacterPoses", fields: [characterId], references: [id], onDelete: SetNull)
  status           ResourceStatus               @default(draft)
  reviewer         String?
  reviewNote       String?
  /// 결합 임베딩 (텍스트+시각 결합 또는 아래 두 컬럼 사용)
  embedding        Unsupported("vector(1024)")?
  /// 텍스트(태그) 임베딩
  embeddingText    Unsupported("vector(1024)")?
  /// 시각(이미지) 임베딩
  embeddingVis     Unsupported("vector(1024)")?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([kind, status])
  @@index([kind, format, status])
  @@index([kind, lowDpi, status])
  @@index([ownerType, ownerId])
  @@index([characterId])
}

/// 사용자 스토리보드 작품
model Project {
  id        String        @id @default(cuid())
  ownerId   String
  owner     User          @relation(fields: [ownerId], references: [id])
  formatId  String
  format    Format        @relation(fields: [formatId], references: [id])
  title     String
  status    ProjectStatus @default(drafting)
  settings  Json          @default("{}")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  pages     Page[]
  sceneDoc  SceneDoc?
  publishes PublishJob[]
  showcases Showcase[]

  @@index([ownerId])
  @@index([ownerId, status])
}

/// 작품의 단일 페이지 — fabricJson = PageJsonV1
model Page {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  index      Int
  templateId String?
  /// PageJsonV1 — packages/shared-schema/src/editor/v1.ts 스키마 준수
  fabricJson Json
  thumbnail  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, index])
  @@index([projectId])
}

/// AI 대본 분석 결과 — Project 1:1
model SceneDoc {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptRaw String
  meta      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scenes    Scene[]
}

/// 장면 단위 분석 결과
model Scene {
  id         String   @id @default(cuid())
  sceneDocId String
  sceneDoc   SceneDoc @relation(fields: [sceneDocId], references: [id], onDelete: Cascade)
  index      Int
  slug       String
  summary    String
  emotion    String?
  view       String?
  pageId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lines      Line[]

  @@unique([sceneDocId, index])
  @@index([sceneDocId])
}

/// 장면 내 대사 한 줄
model Line {
  id        String   @id @default(cuid())
  sceneId   String
  scene     Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  index     Int
  speaker   String?
  text      String
  bubbleId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sceneId, index])
  @@index([sceneId])
}

/// PDF/출판 잡 레코드
model PublishJob {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 현재는 'pdf'만 사용
  kind      String
  status    JobStatus @default(queued)
  pdfUrl    String?
  spec      Json
  preflight Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
}

/// 공개 쇼케이스 (공모전/갤러리)
model Showcase {
  id        String         @id @default(cuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User           @relation(fields: [ownerId], references: [id])
  mode      ShowcaseMode
  contestId String?
  contest   ContestSeason? @relation(fields: [contestId], references: [id])
  likes     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  reactions Reaction[]
  comments  Comment[]

  @@index([ownerId])
  @@index([mode, contestId])
}

/// 쇼케이스 리액션 (좋아요 등)
model Reaction {
  id         String   @id @default(cuid())
  showcaseId String
  showcase   Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  userId     String
  /// 'like' | 'heart' | 'wow'
  kind       String
  createdAt  DateTime @default(now())

  @@unique([showcaseId, userId, kind])
  @@index([showcaseId])
}

/// 공모전 시즌
model ContestSeason {
  id        String     @id @default(cuid())
  name      String
  opensAt   DateTime
  closesAt  DateTime
  resultsAt DateTime?
  rules     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  entries   Showcase[]
}

/// 인쇄소 사양 프리셋 (POD preflight 프로필)
model PrinterProfile {
  id                String   @id @default(cuid())
  /// URL/import 키 — 'bookprint-korea' 등 영문 슬러그
  slug              String   @unique
  name              String
  description       String?  @db.Text
  /// 지원 판형 ID 배열 (빈 배열 = 모두 허용)
  formats           String[]
  bleedMinMm        Float
  bleedMaxMm        Float
  safeMinMm         Float
  imageDpiMinPose   Float
  imageDpiMinBg     Float
  fontEmbedRequired Boolean  @default(true)
  /// 허용 색공간 순서 — ['rgb'] | ['cmyk'] | ['rgb','cmyk']
  colorSpaces       String[]
  /// 최대 페이지 수 (null = 제한 없음)
  maxPages          Int?
  /// 프로필 전용 커스텀 경고 메시지 목록
  customWarnings    String[]
  /// 시스템 프리셋 — true 이면 삭제 불가
  isSystem          Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdById       String?
  createdBy         User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([slug])
}

/// 관리자 액션 감사 로그
model AuditLog {
  id      String   @id @default(cuid())
  actorId String
  action  String
  /// 'entity:id' 형식
  target  String
  payload Json
  at      DateTime @default(now())

  @@index([actorId])
  @@index([target])
  @@index([at])
}

/// 공지사항
model Notice {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  isPinned    Boolean   @default(false)
  /// null 이면 draft (미게시)
  publishedAt DateTime?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt, isPinned])
}

/// 1:1 문의 (Q&A) — 비회원도 가능 (email)
model Inquiry {
  id         String        @id @default(cuid())
  /// null = 비회원
  userId     String?
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  email      String
  subject    String
  body       String        @db.Text
  status     InquiryStatus @default(OPEN)
  adminReply String?       @db.Text
  repliedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

/// Showcase 댓글
model Comment {
  id         String   @id @default(cuid())
  showcaseId String
  showcase   Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  body       String   @db.Text
  /// soft delete
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([showcaseId, createdAt])
}

/// 회사 정보 (사업자 정보 + 운영자 연락처) — 싱글톤 (1 row only)
/// 한국 전자상거래법 표준 + 개인정보보호법 처리 위탁 명시용
/// 싱글톤 id 고정값: 'company-info-singleton'
model CompanyInfo {
  /// 고정 id — 항상 'company-info-singleton' 사용 (upsert 키)
  id                     String  @id @default(cuid())
  // ── 기본 정보 ──
  companyName            String  @default("")
  ceoName                String  @default("")
  // ── 법적 등록 정보 ──
  /// 사업자등록번호 형식: 000-00-00000
  businessRegistrationNo String?
  /// 통신판매업신고번호 형식: 2026-서울-00000
  mailOrderBusinessNo    String?
  // ── 주소/연락처 ──
  address                String  @default("") @db.Text
  phone                  String  @default("")
  email                  String  @default("")
  faxNo                  String?
  // ── 부가정보 (Footer 표시용) ──
  privacyOfficerName     String?
  privacyOfficerEmail    String?
  /// 예: "평일 10:00 ~ 18:00 (점심 12-13시 제외)"
  customerServiceHours   String?
  hostingProvider        String  @default("Vercel · Supabase")
  // ── footer 노출 토글 ──
  /// false 이면 footer/약관에 placeholder 유지. 필수 필드 입력 완료 후 true 로 전환.
  isPublished            Boolean @default(false)
  // ── 메타 ──
  updatedById            String?
  updatedBy              User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
