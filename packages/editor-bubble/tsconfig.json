{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@storywork/editor-core": ["../editor-core/dist/index.d.ts"],
      "@storywork/schema": ["../shared-schema/dist/index.d.ts"],
      "@storywork/schema/editor": ["../shared-schema/dist/editor/v1.d.ts"],
      "@storywork/schema/prisma": ["../shared-schema/dist/prisma.d.ts"],
      "@storywork/schema/license": ["../shared-schema/dist/license/index.d.ts"],
      "@storywork/utils": ["../shared-utils/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
