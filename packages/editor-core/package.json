{
  "name": "@storywork/editor-core",
  "version": "0.0.0",
  "type": "module",
  "description": "fabric.js v6 인스턴스 수명 관리, 좌표계 변환, 이벤트 버스, Schema 라운드트립",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "vitest bench",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@storywork/schema": "workspace:*",
    "@storywork/utils": "workspace:*",
    "fabric": "^6.9.1",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "canvas": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
