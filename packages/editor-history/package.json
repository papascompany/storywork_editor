{
  "name": "@storywork/editor-history",
  "version": "0.0.0",
  "type": "module",
  "description": "Command 기반 undo/redo, 협업 OT 슬롯",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@storywork/editor-core": "workspace:*",
    "@storywork/editor-layers": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "canvas": "^3.0.0",
    "fabric": "^6.9.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
