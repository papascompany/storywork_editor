    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@storywork/editor-core": "workspace:*",
    "fabric": "^6.9.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
