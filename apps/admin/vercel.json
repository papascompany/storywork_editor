{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@storywork/admin",
  "outputDirectory": ".next",
  "ignoreCommand": "cd ../.. && npx turbo-ignore @storywork/admin --fallback=HEAD~1"
}
