# StoryWork 환경변수 예시
# 사용법: cp .env.example .env.local
# .env.local 은 gitignore 됩니다. 절대 커밋하지 마세요.

# ─────────────────────────────────────────────
# PostgreSQL / Supabase DB 연결
# ─────────────────────────────────────────────

# Prisma 연결 URL (pgbouncer 풀링 사용)
# 로컬: supabase start 후 출력되는 DB URL
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?pgbouncer=true&connect_timeout=10"

# Prisma Direct URL (마이그레이션 전용 — 풀링 없이 직접 연결)
DIRECT_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# ─────────────────────────────────────────────
# Supabase 설정
# ─────────────────────────────────────────────

# Supabase 프로젝트 URL (로컬: http://localhost:54321)
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"

# Supabase anon key (공개 — 브라우저에서 사용)
# 로컬: supabase start 후 출력되는 anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase service role key (서버 전용 — 절대 클라이언트에 노출 금지)
# 로컬: supabase start 후 출력되는 service_role key
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─────────────────────────────────────────────
# 앱 URL
# ─────────────────────────────────────────────

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# ─────────────────────────────────────────────
# 관리자 콘솔 (apps/admin 전용)
# ─────────────────────────────────────────────

# 2FA JWT 서명 시크릿 — 최소 32자 랜덤 문자열
# 생성: openssl rand -base64 32
ADMIN_JWT_SECRET="REPLACE_WITH_32_CHAR_RANDOM_SECRET"

# TOTP 발급자 이름 (인증 앱에 표시되는 서비스 이름, 기본: "StoryWork Admin")
# Vercel env 에 등록 필요 (apps/admin 전용)
TOTP_ISSUER="StoryWork Admin"

# ─────────────────────────────────────────────
# Inngest (apps/workers 전용)
# ─────────────────────────────────────────────

# Inngest 이벤트 키 — https://app.inngest.com 에서 발급
INNGEST_EVENT_KEY="your-inngest-event-key"

# Inngest 웹훅 서명 검증 키
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# ─────────────────────────────────────────────
# AI API 키 (M4+ 에서 사용)
# ─────────────────────────────────────────────

# Vercel AI Gateway (권장) — Vercel Dashboard > AI > Gateway 에서 발급
# 게이트웨이 경유 시 아래 두 값 설정 (ANTHROPIC_API_KEY 대신)
# AI_GATEWAY_API_KEY="vai_..."
# AI_GATEWAY_BASE_URL="https://gateway.ai.vercel.app/v1/<team>/<gateway>"

# Anthropic Claude 직접 연결 (게이트웨이 미사용 시 폴백)
# ANTHROPIC_API_KEY="sk-ant-..."

# ── LLM 활성/비활성 제어 ──────────────────────
# CI/CD: 반드시 0 (LLM 호출 금지 — 비용 보호)
# 로컬 개발: 1 로 설정하면 LLM 보강 활성
STORYWORK_LLM=0

# LLM 응답 캐시 사용 여부 (결정론 보장 + 재실행 비용 절감)
# 1: 캐시 파일 우선 읽기 / 응답 자동 저장 (기본 동작)
# 0: 항상 LLM 재호출 (캐시 무시)
STORYWORK_LLM_CACHE=1

# 임베딩 (포즈 검색, ai-recommend)
# VOYAGE_API_KEY="pa-..."
# OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────
# Stripe (M7+ 에서 사용)
# ─────────────────────────────────────────────

# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─────────────────────────────────────────────
# 스케줄 잡 / Cron (apps/web)
# ─────────────────────────────────────────────

# 회원 탈퇴(soft delete) 30일 경과분 hard delete cron 인증 시크릿 (LEGAL-OPS-03 / ADR-0015)
# GET /api/cron/hard-delete-users 는 Authorization: Bearer <CRON_SECRET> 헤더 필수.
# ⚠️ 미설정 시 cron 이 항상 401 → 개인정보 파기(법적 의무)가 실행되지 않으므로
#    프로덕션(Vercel)에 반드시 등록할 것. 생성: openssl rand -base64 32
CRON_SECRET="REPLACE_WITH_RANDOM_SECRET"
