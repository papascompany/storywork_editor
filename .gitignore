# === StoryWork specific ===

# 포즈 자산 마스터 — Git LFS 또는 Storage 업로드로 관리, 레포에 직접 커밋하지 않음
data/poses/raw/**/*.png
data/poses/raw/**/*.svg
data/poses/_failed/

# 메타 파일은 커밋 (라이선스 정책 + 사이드카는 SSOT)
!data/poses/raw/LICENSE.json
!data/poses/raw/*.kp.json

# 인입 산출물 (Storage 업로드)
data/poses/processed/

# Supabase 로컬
supabase/.branches
supabase/.temp

# Local backups (절대 커밋 금지)
*.bak
.env.local.*

# macOS Finder 가 만드는 중복 (예: foo 2.tsx)
**/* 2.*
.vercel

# 빌드 산출물이 src 안에 잘못 emit 되었을 때 (tsc rootDir 미스 방어)
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
packages/*/src/**/*.js.map
