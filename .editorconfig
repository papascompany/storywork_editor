root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2

[Makefile]
indent_style = tab

[*.{png,svg,jpg,jpeg,gif,ico,woff,woff2,ttf,eot}]
end_of_line = unset
charset = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
